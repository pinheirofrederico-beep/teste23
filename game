<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Mini Game de Desviar</title>
    <style>
        /* CSS: O visual do jogo */
        body { margin: 0; display: flex; justify-content: center; align-items: center; height: 100vh; background: #222; font-family: sans-serif; }
        #gameCanvas { border: 4px solid #fff; background: #333; }
        .info { position: absolute; top: 10px; color: white; text-align: center; }
    </style>
</head>
<body>

    <div class="info">
        <h2>Use as Setas (← →) para mover</h2>
        <p id="score">Pontos: 0</p>
    </div>
    <canvas id="gameCanvas" width="400" height="500"></canvas>

    <script>
        // JavaScript: A lógica do jogo
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");
        const scoreElement = document.getElementById("score");

        let car = { x: 175, y: 430, width: 50, height: 60, speed: 7 };
        let obstacles = [];
        let frames = 0;
        let score = 0;
        let gameOver = false;

        // Capturar teclas
        let keys = {};
        window.addEventListener("keydown", e => keys[e.keyCode] = true);
        window.addEventListener("keyup", e => keys[e.keyCode] = false);

        function update() {
            if (gameOver) return;

            // Movimentação
            if (keys[37] && car.x > 0) car.x -= car.speed; // Esquerda
            if (keys[39] && car.x < canvas.width - car.width) car.x += car.speed; // Direita

            // Criar obstáculos a cada 60 frames
            if (frames % 60 === 0) {
                let x = Math.random() * (canvas.width - 50);
                obstacles.push({ x: x, y: -60, width: 50, height: 60 });
            }

            // Mover obstáculos e checar colisão
            obstacles.forEach((obs, index) => {
                obs.y += 5;

                // Colisão (Matemática simples)
                if (car.x < obs.x + obs.width && car.x + car.width > obs.x &&
                    car.y < obs.y + obs.height && car.y + car.height > obs.y) {
                    gameOver = true;
                    alert("Game Over! Pontos: " + score);
                    location.reload(); // Reinicia o jogo
                }

                // Remover se sair da tela e somar ponto
                if (obs.y > canvas.height) {
                    obstacles.splice(index, 1);
                    score++;
                    scoreElement.innerText = "Pontos: " + score;
                }
            });

            frames++;
            draw();
            requestAnimationFrame(update);
        }

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // Desenhar Carro (Azul)
            ctx.fillStyle = "#00ADFF";
            ctx.fillRect(car.x, car.y, car.width, car.height);

            // Desenhar Obstáculos (Vermelho)
            ctx.fillStyle = "#FF4136";
            obstacles.forEach(obs => {
                ctx.fillRect(obs.x, obs.y, obs.width, obs.height);
            });
        }

        update();
    </script>
</body>
</html>
